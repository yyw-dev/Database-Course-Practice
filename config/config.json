{
  "database": {
    "host": "localhost",
    "port": 3306,
    "user": "class_app",
    "password": "your_password_here",
    "database": "class_management_system",
    "connection_pool_size": 10,
    "connection_timeout": 30
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "thread_pool_size": 4,
    "request_timeout": 30,
    "max_request_size": 10485760
  },
  "logging": {
    "level": "info",
    "file": "logs/class_management_system.log",
    "max_file_size": 10485760,
    "backup_count": 5,
    "console_output": true
  },
  "security": {
    "session_timeout": 3600,
    "password_min_length": 8,
    "password_require_uppercase": true,
    "password_require_lowercase": true,
    "password_require_digits": true,
    "password_require_special": false,
    "max_login_attempts": 5,
    "lockout_duration": 900
  },
  "features": {
    "enable_notifications": true,
    "enable_finance_management": true,
    "enable_attendance_tracking": true,
    "enable_activity_management": true,
    "enable_file_uploads": true,
    "max_file_size": 10485760,
    "allowed_file_types": [
      "application/pdf",
      "application/msword",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.ms-excel",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "text/plain",
      "image/jpeg",
      "image/png"
    ]
  },
  "backup": {
    "enabled": true,
    "schedule": "0 2 * * *",
    "retention_days": 30,
    "backup_path": "/var/backups/class_management_system"
  }
}